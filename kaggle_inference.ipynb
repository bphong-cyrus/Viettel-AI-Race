 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 🏥 Vietnamese Medical NER — Inference on Test Set (Kaggle)\n",
    "\n",
    "Run hybrid pipeline (rules + LoRA-tuned LLM) on the test set and produce submission ZIP.\n",
    "\n",
    "**Inputs:**\n",
    "- LoRA adapter from `kaggle_sft_train.ipynb` (uploaded as dataset, or train in same session)\n",
    "- Test set in `input/input/`\n",
    "- Drug dictionary + vocab files\n",
    "\n",
    "**Outputs:**\n",
    "- `output/1.json` … `output/100.json` (one per test record)\n",
    "- `output_hybrid.zip` (ready to submit)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Install + setup"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "!pip install -q -U transformers accelerate peft bitsandbytes\n",
    "!pip install -q editdistance"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os, sys, json, shutil\n",
    "\n",
    "# Data layout\n",
    "WORK_DIR = '/kaggle/working'\n",
    "DATA_ROOT = '/kaggle/input/vtai-race'  # upload as Kaggle dataset\n",
    "LORA_DIR = '/kaggle/input/vtai-lora-adapter/lora_adapter'  # from training notebook\n",
    "\n",
    "os.chdir(WORK_DIR)\n",
    "\n",
    "# Copy code files\n",
    "for f in ['llm_prompts.py', 'llm_inference.py', 'llm_ner_config.py',\n",
    "          'hybrid_pipeline.py', 'v20_pipeline.py', 'drug_dict_v3.py',\n",
    "          'vocab_v5.py', 'evaluate.py', 'scorer.py']:\n",
    "    src = f'{DATA_ROOT}/{f}'\n",
    "    dst = f'{WORK_DIR}/{f}'\n",
    "    if os.path.exists(src):\n",
    "        shutil.copy(src, dst)\n",
    "        print(f\"Copied {f}\")\n",
    "    else:\n",
    "        print(f\"⚠ Not found: {src}\")\n",
    "\n",
    "# Symlink input dir\n",
    "for d in ['input']:\n",
    "    src = f'{DATA_ROOT}/{d}'\n",
    "    dst = f'{WORK_DIR}/{d}'\n",
    "    if os.path.exists(src) and not os.path.exists(dst):\n",
    "        os.symlink(src, dst)\n",
    "\n",
    "BASE_MODEL = \"Qwen/Qwen2.5-7B-Instruct\"  # must match training\n",
    "print(\"Setup OK\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Load base model + LoRA adapter"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import torch\n",
    "from transformers import AutoModelForCausalLM, AutoTokenizer, BitsAndBytesConfig\n",
    "from peft import PeftModel\n",
    "\n",
    "print(f\"GPU: {torch.cuda.get_device_name(0)}\")\n",
    "print(f\"VRAM: {torch.cuda.get_device_properties(0).total_memory / 1e9:.1f} GB\")\n",
    "\n",
    "bnb_config = BitsAndBytesConfig(\n",
    "    load_in_4bit=True,\n",
    "    bnb_4bit_quant_type=\"nf4\",\n",
    "    bnb_4bit_compute_dtype=torch.bfloat16,\n",
    "    bnb_4bit_use_double_quant=True,\n",
    ")\n",
    "\n",
    "print(\"Loading base model in 4-bit...\")\n",
    "model = AutoModelForCausalLM.from_pretrained(\n",
    "    BASE_MODEL,\n",
    "    quantization_config=bnb_config,\n",
    "    device_map=\"auto\",\n",
    "    torch_dtype=torch.bfloat16,\n",
    "    trust_remote_code=True,\n",
    ")\n",
    "tokenizer = AutoTokenizer.from_pretrained(BASE_MODEL, trust_remote_code=True)\n",
    "if tokenizer.pad_token is None:\n",
    "    tokenizer.pad_token = tokenizer.eos_token\n",
    "\n",
    "if os.path.exists(LORA_DIR):\n",
    "    print(f\"Loading LoRA adapter from {LORA_DIR}...\")\n",
    "    model = PeftModel.from_pretrained(model, LORA_DIR)\n",
    "    print(\"Adapter loaded.\")\n",
    "else:\n",
    "    print(f\"⚠ LoRA adapter not found at {LORA_DIR}, using base model only\")\n",
    "\n",
    "model.eval()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Build hybrid pipeline (rules + LLM)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "sys.path.insert(0, WORK_DIR)\n",
    "from llm_inference import LLMExtractor\n",
    "from hybrid_pipeline import HybridNER\n",
    "\n",
    "# Build LLM extractor that uses our loaded model\n",
    "class LoadedLLMExtractor(LLMExtractor):\n",
    \"\"\"Uses already-loaded model instead of loading again.\"\"\"\n",
    "    def __init__(self, model, tokenizer):\n",
    # Skip init — we already have model loaded\n",
    "        self.model = model\n",
    "        self.tokenizer = tokenizer\n",
    "        self._loaded = True\n",
    "        self.model_key = \"qwen2.5-7b-instruct\"\n",
    "\n",
    "    def _build_prompt(self, text):\n",
    "        from llm_prompts import SYSTEM_PROMPT, build_user_prompt\n",
    "        msgs = [\n",
    "            {\"role\": \"system\", \"content\": SYSTEM_PROMPT},\n",
    "            {\"role\": \"user\", \"content\": f\"Trích xuất thực thể y tế từ:\\n{text}\\n\\nJSON:\"}\n",
    "        ]\n",
    "        return self.tokenizer.apply_chat_template(msgs, tokenize=False, add_generation_prompt=True)\n",
    "\n",
    "    def _generate(self, prompt, temperature=None):\n",
    "        inputs = self.tokenizer(prompt, return_tensors=\"pt\", truncation=True, max_length=4096)\n",
    "        inputs = {k: v.to(self.model.device) for k, v in inputs.items()}\n",
    "        with torch.no_grad():\n",
    "            out = self.model.generate(\n",
    "                **inputs,\n",
    "                max_new_tokens=4096,\n",
    "                do_sample=False,\n",
    "                repetition_penalty=1.05,\n",
    "                pad_token_id=self.tokenizer.pad_token_id,\n",
    "            )\n",
    "        return self.tokenizer.decode(out[0][inputs[\"input_ids\"].shape[1]:], skip_special_tokens=True)\n",
    "\n",
    "extractor = LoadedLLMExtractor(model, tokenizer)\n",
    "hybrid = HybridNER(llm_extractor=extractor, use_llm=True, rule_weight=0.6)\n",
    "print(\"Hybrid pipeline ready.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Run on all test inputs"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import zipfile, time\n",
    "from pathlib import Path\n",
    "\n",
    "INPUT_DIR = 'input/input'\n",
    "OUTPUT_DIR = '/kaggle/working/output'\n",
    "ZIP_PATH = '/kaggle/working/output_hybrid.zip'\n",
    "os.makedirs(OUTPUT_DIR, exist_ok=True)\n",
    "\n",
    "input_files = sorted(Path(INPUT_DIR).glob('*.txt'),\n",
    "                     key=lambda p: int(p.stem) if p.stem.isdigit() else 999)\n",
    "print(f\"Found {len(input_files)} test files\")\n",
    "\n",
    "t0 = time.time()\n",
    "type_counts = {'THUỐC': 0, 'TRIỆU_CHỨNG': 0, 'CHẨN_ĐOÁN': 0}\n",
    "total_entities = 0\n",
    "for i, in_file in enumerate(input_files, 1):\n",
    "    sid = in_file.stem\n",
    "    out_file = f'{OUTPUT_DIR}/{sid}.json'\n",
    "    text = in_file.read_text(encoding='utf-8')\n",
    "    ents = hybrid.extract(text)\n",
    "    with open(out_file, 'w', encoding='utf-8') as f:\n",
    "        json.dump(ents, f, ensure_ascii=False, indent=2)\n",
    "    total_entities += len(ents)\n",
    "    for e in ents:\n",
    "        type_counts[e['type']] = type_counts.get(e['type'], 0) + 1\n",
    "    if i % 10 == 0:\n",
    "        elapsed = time.time() - t0\n",
    "        eta = elapsed / i * (len(input_files) - i)\n",
    "        print(f\"  [{i}/{len(input_files)}] {elapsed:.1f}s elapsed, ETA {eta:.1f}s\")\n",
    "\n",
    "elapsed = time.time() - t0\n",
    "print(f\"\\n✓ Done in {elapsed:.1f}s\")\n",
    "print(f\"Total entities: {total_entities}, types: {type_counts}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Build submission ZIP"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "with zipfile.ZipFile(ZIP_PATH, 'w', zipfile.ZIP_DEFLATED) as zf:\n",
    "    for i in range(1, len(input_files) + 1):\n",
    "        jf = f'{OUTPUT_DIR}/{i}.json'\n",
    "        if os.path.exists(jf):\n",
    "            zf.write(jf, f'output/{i}.json')\n",
    "print(f\"✓ Created {ZIP_PATH}\")\n",
    "print(f\"  Size: {os.path.getsize(ZIP_PATH) / 1024:.1f} KB\")\n",
    "\n",
    "# List contents\n",
    "with zipfile.ZipFile(ZIP_PATH) as zf:\n",
    "    print(f\"  Contains {len(zf.namelist())} files\")\n",
    "    for n in zf.namelist()[:5]:\n",
    "        print(f\"    {n}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Sanity check output"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import json\n",
    "for i in [1, 5, 50]:\n",
    "    p = f'{OUTPUT_DIR}/{i}.json'\n",
    "    if os.path.exists(p):\n",
    "        data = json.load(open(p, encoding='utf-8'))\n",
    "        print(f\"\\n=== Output {i} ({len(data)} entities) ===\")\n",
    "        for e in data[:10]:\n",
    "            print(f\"  [{e['type']}] '{e['text']}' assert={e['assertions']} CUI={e['candidates']}\")"
   ]
  }
